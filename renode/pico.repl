nvic: IRQControllers.NVIC @ sysbus 0xE000E000
    priorityMask: 0xF0

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m33"
    nvic: nvic

flash: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x200000

ram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x80000

uart: UART.PL011 @ sysbus 0x40000000
    frequency: 125000000